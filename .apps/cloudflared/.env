CLOUDFLARED<__INSTANCE>__ENABLED='false'
CLOUDFLARED<__INSTANCE>__CONTAINER_NAME='cloudflared<__instance>'
CLOUDFLARED<__INSTANCE>__HOSTNAME='Cloudflared<__Instance>'
CLOUDFLARED<__INSTANCE>__NETWORK_MODE=''
CLOUDFLARED<__INSTANCE>__RESTART='unless-stopped'
CLOUDFLARED<__INSTANCE>__STORAGE_ON=''     # Blank uses DOCKER_STORAGE_ON value. Set to YES/NO to override
CLOUDFLARED<__INSTANCE>__STORAGE2_ON=''    # Blank uses DOCKER_STORAGE2_ON value. Set to YES/NO to override
CLOUDFLARED<__INSTANCE>__STORAGE3_ON=''    # Blank uses DOCKER_STORAGE3_ON value. Set to YES/NO to override
CLOUDFLARED<__INSTANCE>__STORAGE4_ON=''    # Blank uses DOCKER_STORAGE4_ON value. Set to YES/NO to override
CLOUDFLARED<__INSTANCE>__TAG='latest'
