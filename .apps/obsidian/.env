OBSIDIAN<__INSTANCE>__ENABLED='false'
OBSIDIAN<__INSTANCE>__CONTAINER_NAME='obsidian<__instance>'
OBSIDIAN<__INSTANCE>__HOSTNAME='Obsidian<__Instance>'
OBSIDIAN<__INSTANCE>__NETWORK_MODE=''
OBSIDIAN<__INSTANCE>__PORT_3000='3000'
OBSIDIAN<__INSTANCE>__PORT_3001='3001'
OBSIDIAN<__INSTANCE>__RESTART='unless-stopped'
OBSIDIAN<__INSTANCE>__STORAGE_ON=''     # Blank uses DOCKER_STORAGE_ON value. Set to YES/NO to override
OBSIDIAN<__INSTANCE>__STORAGE2_ON=''    # Blank uses DOCKER_STORAGE2_ON value. Set to YES/NO to override
OBSIDIAN<__INSTANCE>__STORAGE3_ON=''    # Blank uses DOCKER_STORAGE3_ON value. Set to YES/NO to override
OBSIDIAN<__INSTANCE>__STORAGE4_ON=''    # Blank uses DOCKER_STORAGE4_ON value. Set to YES/NO to override
OBSIDIAN<__INSTANCE>__TAG='latest'
