IMMICH<__INSTANCE>__ENABLED='false'
IMMICH<__INSTANCE>__CONTAINER_NAME='immich<__instance>'
IMMICH<__INSTANCE>__HOSTNAME='Immich<__Instance>'
IMMICH<__INSTANCE>__NETWORK_MODE=''
IMMICH<__INSTANCE>__PORT_2283='2283'
IMMICH<__INSTANCE>__POSTGRES_TAG='14-vectorchord0.4.3-pgvectors0.2.0'
IMMICH<__INSTANCE>__REDIS_TAG='9-alpine'
IMMICH<__INSTANCE>__RESTART='unless-stopped'
IMMICH<__INSTANCE>__STORAGE_ON=''     # Blank uses DOCKER_STORAGE_ON value. Set to YES/NO to override
IMMICH<__INSTANCE>__STORAGE2_ON=''    # Blank uses DOCKER_STORAGE2_ON value. Set to YES/NO to override
IMMICH<__INSTANCE>__STORAGE3_ON=''    # Blank uses DOCKER_STORAGE3_ON value. Set to YES/NO to override
IMMICH<__INSTANCE>__STORAGE4_ON=''    # Blank uses DOCKER_STORAGE4_ON value. Set to YES/NO to override
IMMICH<__INSTANCE>__TAG='release'
IMMICH<__INSTANCE>__UPLOAD_LOCATION="${DOCKER_VOLUME_CONFIG?}/immich<__instance>"
