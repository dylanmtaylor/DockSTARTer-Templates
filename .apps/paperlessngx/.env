# NOTE: Official Paperless-NGX docs recommend PostgreSQL for new installations.
PAPERLESSNGX<__INSTANCE>__ENABLED='false'
PAPERLESSNGX<__INSTANCE>__CONTAINER_NAME='paperlessngx<__instance>'
PAPERLESSNGX<__INSTANCE>__HOSTNAME='PaperlessNGX<__Instance>'
PAPERLESSNGX<__INSTANCE>__NETWORK_MODE=''
PAPERLESSNGX<__INSTANCE>__PORT_8000='8000'
PAPERLESSNGX<__INSTANCE>__POSTGRES_TAG='18'
PAPERLESSNGX<__INSTANCE>__REDIS_TAG='8'
PAPERLESSNGX<__INSTANCE>__RESTART='unless-stopped'
PAPERLESSNGX<__INSTANCE>__STORAGE_ON=''     # Blank uses DOCKER_STORAGE_ON value. Set to YES/NO to override
PAPERLESSNGX<__INSTANCE>__STORAGE2_ON=''    # Blank uses DOCKER_STORAGE2_ON value. Set to YES/NO to override
PAPERLESSNGX<__INSTANCE>__STORAGE3_ON=''    # Blank uses DOCKER_STORAGE3_ON value. Set to YES/NO to override
PAPERLESSNGX<__INSTANCE>__STORAGE4_ON=''    # Blank uses DOCKER_STORAGE4_ON value. Set to YES/NO to override
PAPERLESSNGX<__INSTANCE>__TAG='latest'
